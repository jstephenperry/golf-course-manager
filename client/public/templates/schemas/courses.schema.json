{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fairwayhq.example/schemas/courses.schema.json",
  "title": "Courses import",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name"],
    "additionalProperties": true,
    "properties": {
      "id": { "type": "string", "description": "Optional; auto-generated as crs_<12hex>." },
      "name": { "type": "string", "minLength": 1 },
      "frontNineId": {
        "type": ["string", "null"],
        "description": "Optional FK → Nine.id. Required for a course to be playable (show in tee sheet / tournament selectors). If set, that Nine must already exist."
      },
      "backNineId": {
        "type": ["string", "null"],
        "description": "Optional FK → Nine.id. Omit for 9-hole courses; set for 18-hole courses. If set, that Nine must already exist."
      },
      "rating": { "type": "number" },
      "slope": { "type": "integer" },
      "status": { "enum": ["Open", "Closed", "Cart Path Only"] },
      "openTime": { "type": "string", "description": "HH:MM, 24-hour" },
      "closeTime": { "type": "string", "description": "HH:MM, 24-hour" },
      "notes": { "type": "string" }
    }
  }
}
