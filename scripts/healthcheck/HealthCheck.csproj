<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Minimal container HEALTHCHECK probe.

    The aspnet:*-chiseled image has no shell, curl, or wget, so a normal
    `CMD curl -f http://localhost:8080/api/health` is impossible. This tiny
    console app is the probe: it does one HTTP GET and maps the result to a
    process exit code (0 = healthy, 1 = unhealthy). It is built in the
    Containerfile's SDK stage and copied into the runtime image, where it is
    invoked via the framework-dependent `dotnet HealthCheck.dll <url>`.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>HealthCheck</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

</Project>
